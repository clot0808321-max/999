<!doctype html><html lang="zh-Hant"><head><%- include('meta') %></head><body>
<%- include('partials-header', {cartCount}) %>

<section class="bj-hero">
  <img src="/images/new-hero.jpg" alt="888台灣商店橫幅">
</section>

<section class="bj-news">
  <span class="speaker">🔊NEWS</span>
  <marquee>👍 外省運費實報實銷 👍　全區可配送｜商品價格與庫存請以下單頁面為準｜訂貨後商家會依照後台訂單安排出貨</marquee>
</section>

<main class="bj-shop-shell">
  <h1 class="bj-main-title">888台灣商店商品總覽</h1>

  <div class="bj-product-layout" id="products">
    <aside class="bj-category-side">
      <input id="productSearch" class="bj-search" type="search" placeholder="搜尋內容..." autocomplete="off">
      <a class="bj-cat-btn <%= !currentCat ? 'active' : '' %>" href="/#products">全部</a>
      <% categories.forEach(c => { %>
        <a class="bj-cat-btn <%= currentCat === c.id ? 'active' : '' %>" href="/?cat=<%= c.id %>#products"><%= c.name %></a>
      <% }) %>
    </aside>

    <section class="bj-list-area" aria-label="商品列表">
      <% if (products.length) { %>
        <div class="bj-product-list">
          <% products.forEach(p => { %><%- include('product-card', {p}) %><% }) %>
        </div>
        <div id="searchEmpty" class="empty bj-search-empty" style="display:none;">找不到符合搜尋的商品。</div>
      <% } else { %>
        <div class="empty">這個分類目前沒有商品。</div>
      <% } %>
    </section>
  </div>
</main>

<a class="floating-tg" href="https://t.me/TWSHOP888" target="_blank" rel="noopener" aria-label="Telegram客服"><img src="/images/tg-plane-orange.png" alt="Telegram客服"></a>
<a class="floating-cart" href="/cart">🛒 <%= cartCount || 0 %></a>
<script src="/js/main.js"></script>
</body></html>
