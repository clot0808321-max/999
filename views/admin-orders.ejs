<!doctype html><html lang="zh-Hant"><head><%- include('meta') %></head><body>
<div class="admin-layout"><%- include('partials-admin-nav') %>
<main class="admin-main">
  <h1>訂單管理</h1>
  <table><tr><th>編號</th><th>客戶</th><th>電話</th><th>金額</th><th>狀態</th><th>時間</th><th></th></tr>
  <% orders.forEach(o => { %><tr><td>#<%= o.id %></td><td><%= o.customer_name %></td><td><%= o.phone %></td><td>$<%= formatPrice(o.total) %></td><td><%= o.status %></td><td><%= o.created_at %></td><td><a href="/admin/orders/<%= o.id %>">查看</a></td></tr><% }) %>
  </table>
</main></div></body></html>