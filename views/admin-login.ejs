<!doctype html><html lang="zh-Hant"><head><%- include('meta') %></head><body class="login-body">
<form class="login-card" action="/admin/login" method="post" autocomplete="off">
  <h1>888台灣商店後台</h1>
  <% if (error) { %><p class="error"><%= error %></p><% } %>
  <label>帳號<input name="username" autocomplete="off" required></label>
  <label>密碼<input name="password" type="password" autocomplete="new-password" required></label>
  <button class="btn">登入後台</button>
  <a href="/">回前台</a>
</form>
</body></html>