<article class="catalog-card bj-item" data-name="<%= p.name %>" data-desc="<%= p.description || '' %>" data-cat="<%= p.category_name || '' %>">
  <a href="/product/<%= p.id %>" class="pic-box bj-pic">
    <img src="<%= p.image || '/uploads/sample-1.svg' %>" alt="<%= p.name %>">
  </a>
  <div class="catalog-info bj-info">
    <h3><a href="/product/<%= p.id %>"><%= p.name %></a></h3>
    <p class="sub"><%= p.description || p.category_name || '888台灣商店商品' %></p>
    <p class="stock-line <%= p.stock <= 0 ? 'soldout' : '' %>"><%= p.stock > 0 ? ('現貨 ' + p.stock + ' ' + (p.unit || '件')) : '已售完' %></p>
    <div class="bj-card-bottom">
      <div class="price-line">$<%= formatPrice(p.price) %><span>/<%= p.unit || '件' %></span></div>
      <form action="/cart/add" method="post">
        <input type="hidden" name="product_id" value="<%= p.id %>">
        <input type="hidden" name="quantity" value="1">
        <button class="order-btn bj-add-btn" title="加入購物車" <%= p.stock <= 0 ? 'disabled' : '' %>>＋</button>
      </form>
    </div>
  </div>
</article>
