<!doctype html><html lang="zh-Hant"><head><%- include('meta') %></head><body>
<div class="admin-layout"><%- include('partials-admin-nav') %>
<main class="admin-main">
  <h1>後台首頁</h1>
  <div class="stats">
    <div>商品數量<strong><%= productTotal %></strong></div>
    <div>訂單數量<strong><%= orderTotal %></strong></div>
    <div>新訂單<strong><%= newOrders %></strong></div>
  </div>
  <h2>最近訂單</h2>
  <table><tr><th>編號</th><th>客戶</th><th>電話</th><th>金額</th><th>狀態</th><th></th></tr>
  <% recentOrders.forEach(o => { %><tr><td>#<%= o.id %></td><td><%= o.customer_name %></td><td><%= o.phone %></td><td>$<%= o.total %></td><td><%= o.status %></td><td><a href="/admin/orders/<%= o.id %>">查看</a></td></tr><% }) %>
  </table>
</main></div>
</body></html>